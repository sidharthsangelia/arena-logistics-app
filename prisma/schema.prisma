generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum OrgPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum KycDocType {
  PAN_CARD // individual / founder / proprietor PAN
  COMPANY_PAN // company's PAN (commercial shipments) — distinct from the founder's PAN_CARD
  ADHAR_CARD
  GST_CERTIFICATE
  IEC_CODE
  MSME_CERTIFICATE
  INCORPORATION_CERT
  CANCELLED_CHEQUE
  BANK_STATEMENT
  TRADE_LICENSE
  AUTHORIZED_SIGNATORY
  LUT // Letter of Undertaking — zero-rated/no-IGST exports
  OTHER
}

// NOTE: Vendor is intentionally NOT an enum.
// Your adapter registry already uses string IDs ("aramex", "skart", "fedex").
// A DB enum means a migration every time you add a carrier — avoid it.

// ─────────────────────────────────────────────
// Org (tenant root)
// ─────────────────────────────────────────────

model Org {
  id         String  @id @default(cuid())
  clerkOrgId String  @unique
  slug       String  @unique
  name       String
  logoUrl    String?
  plan       OrgPlan @default(FREE)

  // Razorpay billing stubs — optional, populate when payment is wired up
  razorpayCustomerId     String? @unique
  razorpaySubscriptionId String? @unique

  // Relations
  vendorKeys VendorKey[]
  clients    Client[]
  quotes     Quote[]
  documents  ClientDocument[]

  markupPercent       Decimal @default(30.000) @db.Decimal(6, 3)
  isBusinessAssociate Boolean @default(false) // flips markup down (e.g. to 15%) when true — set by you/ops, not self-serve; gates the /clients route

  wallet         Wallet?
  kycDocuments   KycDocument[]
  addresses      Address[]
  shipments      Shipment[]
  baApplications BaApplication[]
  bookingDrafts  BookingDraft[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  companyName  String?
  contactName  String?
  email        String?
  phone        String?
  addressLine1 String?
  city         String?
  state        String?
  country      String?
  postalCode   String?
  notes        String?

  skipPayment Boolean @default(false)
  profileCompletedAt DateTime?
  emailEvents QuoteEmailEvent[]

  // ── client-facing shipment emails (business associates only) ──
  //
  // A BA books on behalf of its own clients, and milestone emails already reached
  // those clients before this existed. That was never something the BA agreed to,
  // so it is now opt-in: with clientEmailsEnabled false, milestone mail goes to
  // the BA's own address instead of the client's. Nobody goes dark either way.
  //
  // clientEmailMilestones is the subset of statuses the client hears about. Only
  // the five EMAIL_MILESTONE_STATUSES are ever stored here; the rest of the enum
  // has no customer-facing email at all. An empty list with the toggle on would
  // send nothing, which the settings form refuses to save.
  //
  // Ignored entirely for standard orgs, who ship for themselves and have no
  // clients to shield.
  clientEmailsEnabled   Boolean          @default(false)
  clientEmailMilestones ShipmentStatus[] @default([BOOKED, PROCESSING, IN_TRANSIT, OUT_FOR_DELIVERY, DELIVERED])
  /// Where a client's reply lands. Falls back to Org.email when unset.
  clientEmailReplyTo    String?

  notifications Notification[]

  @@index([slug])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────
// VendorKey (BYOK — one row per carrier per org)
// ─────────────────────────────────────────────

model VendorKey {
  id    String @id @default(cuid())
  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  vendorId String // "aramex" | "skart" | "fedex" — matches adapter registry
  label    String // display name e.g. "Aramex Production"
  notes    String?

  encryptedPayload String
  iv               String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, vendorId])
  @@index([orgId])
}

// ─────────────────────────────────────────────
// Client
// ─────────────────────────────────────────────

model Client {
  id    String @id @default(cuid())
  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  companyName  String
  contactName  String?
  email        String?
  phone        String?
  addressLine1 String?
  city         String?
  state        String?
  country      String?
  postalCode   String?
  notes        String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  companyKind CompanyKind @default(INDIVIDUAL)

  // Per-client override of the BA's org-wide clientEmailsEnabled setting.
  // Deliberately three-state rather than a boolean: INHERIT means "whatever the
  // org setting says", so flipping the org toggle still moves every client the BA
  // never made an explicit decision about. A boolean would have had to be
  // backfilled to a concrete value, freezing today's default in place forever.
  emailPreference ClientEmailPreference @default(INHERIT)

  kycDocuments KycDocument[]
  addresses    Address[]
  shipments    Shipment[]

  quotes    Quote[]
  documents ClientDocument[]

  @@index([orgId])
  @@index([orgId, companyName])
  @@index([email])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────
// Quote
// ─────────────────────────────────────────────

model Quote {
  id    String @id @default(cuid())
  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  quoteNumber String

  // Carrier / product
  vendorId    String
  vendorName  String
  productName String

  // Pricing
  currency      String
  subtotal      Decimal @db.Decimal(14, 4)
  tax           Decimal @db.Decimal(14, 4)
  total         Decimal @db.Decimal(14, 4)
  markupPercent Decimal @db.Decimal(6, 3)
  quotedTotal   Decimal @db.Decimal(14, 4)

  // Transit
  tatDays Int?

  // Immutable snapshots
  chargesSnapshot Json
  requestSnapshot Json

  // Generated PDF
  pdfUrl String?
  pdfKey String?

  // Validity
  validUntil DateTime

  // Workflow
  status QuoteStatus @default(DRAFT)

  // Client (optional — may be assigned after creation)
  clientId          String?
  client            Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  emailEvents       QuoteEmailEvent[]
  // Store the last Resend email ID so we can correlate webhook events
  lastResendEmailId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, quoteNumber])
  @@index([orgId])
  @@index([orgId, status])
  @@index([clientId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// ClientDocument (KYC / document vault)
// ─────────────────────────────────────────────

model ClientDocument {
  id String @id @default(cuid())

  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  docType     KycDocType
  label       String
  description String?

  fileUrl  String
  fileKey  String
  fileName String
  fileSize Int
  mimeType String

  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orgId])
  @@index([clientId])
  @@index([orgId, docType])
  @@index([clientId, docType])
}

model QuoteEmailEvent {
  id    String @id @default(cuid())
  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  // Resend's email ID — links all events for the same send
  resendEmailId String

  event      EmailEvent
  // Resend sends recipient's IP/userAgent on open/click — useful for ops
  userAgent  String?
  ipAddress  String?
  // For click events
  clickedUrl String?

  createdAt DateTime @default(now())

  @@index([quoteId])
  @@index([orgId])
  @@index([resendEmailId])
}

enum EmailEvent {
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
}

// Domestic Air Shipment excel parsed rate data

enum RateVendor {
  EDS
  INDIGO
  AIR_INDIA
}

enum CargoType {
  GCR
  LEAN
  SCR
  HEA
  XPS
  DGR
  PRIME
}

model Airport {
  iataCode String @id @db.Char(3)

  city     String?
  state    String?
  isActive Boolean @default(true)

  originRateCards      RateCard[] @relation("OriginAirport")
  destinationRateCards RateCard[] @relation("DestinationAirport")

  createdAt DateTime @default(now())

  @@map("airports")
}

model RateVersion {
  id String @id @default(cuid())

  vendor RateVendor

  effectiveFrom DateTime
  effectiveTo   DateTime?

  isActive Boolean @default(false)
  isStaged Boolean @default(true)

  sourceFilename String

  uploadedBy String?

  uploadedAt DateTime @default(now())

  activatedAt DateTime?
  activatedBy String?

  notes String?

  rateCards  RateCard[]
  awbCharges VendorAwbCharge[]

  @@index([vendor, isActive])
}

model RateCard {
  id String @id @default(cuid())

  versionId String
  version   RateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  vendor RateVendor

  origin      String
  destination String

  originAirport      Airport @relation("OriginAirport", fields: [origin], references: [iataCode])
  destinationAirport Airport @relation("DestinationAirport", fields: [destination], references: [iataCode])

  cargoType CargoType

  commodity String?

  volDivisor Int @default(6000)

  rateIncludesSurcharges Boolean @default(false)

  region String?

  flightNo String?
  airline  String?
  depTime  String?
  arrTime  String?
  timeSlab String?

  consolCode String?

  isTransit         Boolean @default(false)
  opsSuspended      Boolean @default(false)
  componentMismatch Boolean @default(false)

  sector String?

  applicableFlightScope String?

  effectiveDate DateTime?

  remarks String?

  slabs      RateSlab[]
  surcharges FlightSurcharge[]

  createdAt DateTime @default(now())

  @@index([origin, destination])
  @@index([vendor, origin, destination, cargoType])
}

model RateSlab {
  id String @id @default(cuid())

  rateCardId String

  rateCard RateCard @relation(fields: [rateCardId], references: [id], onDelete: Cascade)

  slabLabel String

  weightMin Decimal @db.Decimal(10, 2)

  weightMax Decimal? @db.Decimal(10, 2)

  ratePerKg Decimal @db.Decimal(12, 4)

  minCharge Decimal? @db.Decimal(12, 2)

  rate100kg Decimal? @db.Decimal(12, 4)

  flatRate Decimal? @db.Decimal(12, 4)

  miscCharges Decimal? @db.Decimal(12, 4)

  airportOut Decimal? @db.Decimal(12, 4)

  airportRet Decimal? @db.Decimal(12, 4)

  surchargeComp Decimal? @db.Decimal(12, 4)

  createdAt DateTime @default(now())

  @@index([rateCardId])
}

model FlightSurcharge {
  id String @id @default(cuid())

  rateCardId String

  rateCard RateCard @relation(fields: [rateCardId], references: [id], onDelete: Cascade)

  surchargeType String

  flightNo String?

  surchargePerKg Decimal @db.Decimal(12, 4)

  surchargeText String?

  appliesToCommodity String?

  createdAt DateTime @default(now())

  @@index([rateCardId])
}

model VendorAwbCharge {
  id String @id @default(cuid())

  versionId String

  version RateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  vendor RateVendor

  chargeType String

  amountPerKg Decimal? @db.Decimal(12, 4)

  amountFlat Decimal? @db.Decimal(12, 4)

  minAmount Decimal? @db.Decimal(12, 4)

  appliesTo String?

  notes String?

  createdAt DateTime @default(now())

  @@index([versionId])
}

model QuoteLog {
  id String @id @default(cuid())

  origin      String
  destination String

  cargoType String

  actualWeightKg Decimal @db.Decimal(12, 2)

  chargeableWeight Decimal @db.Decimal(12, 2)

  selectedVendor String?

  totalQuote Decimal? @db.Decimal(12, 2)

  bookingId String?

  createdAt DateTime @default(now())

  @@index([createdAt])
}

enum PartyType {
  ORG // KYC/Address owner is the Org itself (shipping for itself)
  CLIENT // KYC/Address owner is a Client (Org booking on their behalf)
}

enum CompanyKind {
  INDIVIDUAL
  COMPANY
}

enum AddressKind {
  PICKUP
  DELIVERY
  BILLING
  OTHER // warehouse, registered office, etc. — free "any other" address-book type
}

// CSB-IV / CSB-V / Commercial — Indian customs export categories.
// Drives which KYC docs are required and how customs paperwork is handled.
// CSB4 is only valid while total declared value < ₹25,000; at/above that
// threshold a shipment must be CSB5 or COMMERCIAL (enforced in the app layer).
enum ShipmentType {
  CSB4
  CSB5
  COMMERCIAL
}

enum ShipmentStatus {
  DRAFT // form in progress, not yet submitted
  PENDING_PAYMENT // service selected, awaiting wallet debit
  BOOKED // payment captured, sitting in ops queue
  PROCESSING // ops has picked it up
  DOCUMENTS_PENDING // ops needs more docs (AWB etc.) before moving
  IN_TRANSIT
  CUSTOMS_HOLD
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  ON_HOLD
}

enum ShipmentDocType {
  INVOICE // mandatory, fresh per shipment
  AIRWAY_BILL
  PACKING_LIST
  CUSTOMS_DECLARATION
  CERTIFICATE_OF_ORIGIN
  INSURANCE_CERT
  POD // proof of delivery
  OTHER
}

enum WalletTxnType {
  TOP_UP
  SHIPMENT_DEBIT
  REFUND
  ADJUSTMENT // legacy, direction ambiguous — use MANUAL_CREDIT / MANUAL_DEBIT instead
  MANUAL_CREDIT // ops added money by hand, e.g. a NEFT or cheque received offline
  MANUAL_DEBIT // ops took money out by hand, e.g. correcting an over-credit
}

enum WalletTxnStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

enum BaApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// KycDocument — polymorphic: belongs to an Org
// (shipping for itself) OR a Client (Org booking
// on their behalf). Exactly one FK is set.
// Same spirit as your existing ClientDocument —
// this is the generalized successor; once this
// is in place you can fold ClientDocument's data
// into it, or keep both running side by side.
// ─────────────────────────────────────────────

model KycDocument {
  id String @id @default(cuid())

  partyType PartyType
  orgId     String?
  org       Org?      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  docType     KycDocType
  label       String
  docNumber   String? // e.g. PAN number, GSTIN — queryable without opening the file
  description String?

  fileUrl  String
  fileKey  String
  fileName String
  fileSize Int
  mimeType String

  verifiedAt DateTime? // ops marks this once checked
  verifiedBy String?
  expiresAt  DateTime? // optional — IEC/trade license renewals etc.

  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  // exactly one of orgId / clientId should be non-null — enforce in app layer
  // (add a DB CHECK constraint via raw SQL migration if you want belt-and-braces)

  @@index([orgId])
  @@index([clientId])
  @@index([orgId, docType])
  @@index([clientId, docType])
}

// ─────────────────────────────────────────────
// Address — polymorphic, same pattern as KycDocument.
// Reusable address-book entries for pickup/delivery/billing.
// ─────────────────────────────────────────────

model Address {
  id String @id @default(cuid())

  orgId    String?
  org      Org?    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  label String? // "Warehouse 2", "Registered office" — optional nickname for reuse
  kind  AddressKind? // default/suggested use (pickup/delivery/billing) for address-book filtering — not enforced; any saved address can still be picked for any role on a shipment

  contactName  String?
  contactPhone String?
  contactEmail String? // optional — address-book entries can carry an email for notifications/invoice

  line1      String
  line2      String?
  city       String
  state      String?
  country    String
  postalCode String

  // for serviceability lookups against your rate cards / pincode coverage
  latitude  Float?
  longitude Float?

  isDefault Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  pickupShipments   Shipment[] @relation("PickupAddress")
  deliveryShipments Shipment[] @relation("DeliveryAddress")
  billingShipments  Shipment[] @relation("BillingAddress")

  @@index([orgId])
  @@index([clientId])
  @@index([postalCode])
  @@index([orgId, kind])
  @@index([clientId, kind])
}

// ─────────────────────────────────────────────
// Wallet + ledger — Org only.
// Org's wallet pays for its own shipments AND
// any shipment it books on behalf of a Client
// (confirmed: BA fronts the cost, Client has no
// separate wallet of its own).
// Balance cached on Wallet for fast reads;
// WalletTransaction is the append-only source of
// truth. Razorpay fields are nullable stubs for now.
// ─────────────────────────────────────────────

model Wallet {
  id    String @id @default(cuid())
  orgId String @unique
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  balance  Decimal @default(0) @db.Decimal(14, 4)
  currency String  @default("INR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[]
}

model WalletTransaction {
  id       String @id @default(cuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type   WalletTxnType
  status WalletTxnStatus @default(PENDING)

  amount   Decimal @db.Decimal(14, 4) // always positive; type determines direction
  currency String  @default("INR")

  balanceAfter Decimal? @db.Decimal(14, 4) // running balance after this txn, set at write time

  shipmentId String?
  shipment   Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  // Razorpay stubs — populate once payments are wired up
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  notes String?

  // Who moved this money, when a human did. Null for anything the system wrote
  // (shipment debits, webhook credits). The display name is snapshotted so the
  // ledger renders without a Clerk lookup per row, and still reads correctly if
  // the person later leaves the team.
  createdByUserId String?
  createdByName   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([razorpayOrderId])
  @@index([walletId])
  @@index([shipmentId])
  @@index([razorpayPaymentId])
  @@index([walletId, createdAt])
}

// ─────────────────────────────────────────────
// Shipment — the actual booking.
// orgId = who's booking/paying (always set).
// clientId = who it's FOR, if not the Org itself
//   (null = Org shipping for itself,
//    set  = Org booking on behalf of that Client).
// ─────────────────────────────────────────────

model Shipment {
  id    String @id @default(cuid())
  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  shipmentNumber String @unique // human-facing tracking-style ID, e.g. "SHP-2026-00123"

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // ── customer-facing contact snapshot ──
  // Who receives the shipment status emails (booking confirmation + each
  // milestone). Resolved and frozen at booking time: for a BA org booking on
  // behalf of a client this is the CLIENT (the real sender); otherwise it's the
  // consignor entered in the wizard. Snapshotted here because the consignor's
  // email is not otherwise reliably persisted (the pickup address may be a
  // different location), and so later status emails need no re-derivation.
  senderEmail String? // recipient for status emails; null = no email on file
  senderName  String? // greeting name, e.g. "Hi Adnan,"

  // ── addresses ──
  pickupAddressId String
  pickupAddress   Address @relation("PickupAddress", fields: [pickupAddressId], references: [id])

  deliveryAddressId String
  deliveryAddress   Address @relation("DeliveryAddress", fields: [deliveryAddressId], references: [id])

  billingAddressId      String?
  billingAddress        Address? @relation("BillingAddress", fields: [billingAddressId], references: [id])
  billingSameAsDelivery Boolean  @default(true)

  // ── package / cargo details ──
  packages PackageItem[]

  // CSB4 / CSB5 / COMMERCIAL — set once packages are entered. Nullable so a
  // half-finished DRAFT (or legacy row) can exist without it.
  shipmentType ShipmentType?

  declaredCargoType       String? // free text, or map to your existing CargoType enum if useful here too
  totalActualWeightKg     Decimal? @db.Decimal(12, 2)
  totalChargeableWeightKg Decimal? @db.Decimal(12, 2)

  // ── first-mile (door → carrier hub) pickup ──
  // Only relevant when the customer opts into door pickup. The chosen
  // domestic courier (via Shipmozo) that carries the parcel from the sender's
  // door to the selected international vendor's nearest hub, priced with the
  // org's markup already applied. Snapshotted at booking time like the main
  // service, so later rate/markup changes don't rewrite history.
  pickupIncluded          Boolean  @default(false)
  firstMileVendorId       String?
  firstMileVendorName     String?
  firstMileCharge         Decimal? @db.Decimal(14, 4)
  firstMileHubLabel       String? // which hub the parcel is routed to (e.g. "Dwarka, New Delhi")
  firstMileChargeSnapshot Json? // full first-mile price breakdown shown at selection time

  // Payment collected on arrival at the hub instead of up-front — set for
  // orgs with payments turned off (Org.skipPayment). The shipment still
  // becomes BOOKED and enters the ops queue, but flagged so ops can filter
  // "payment pending" bookings and follow up.
  paymentDeferred Boolean @default(false)

  // ── deferred payment collection ──
  // Only meaningful when paymentDeferred is true. Both fields are DERIVED from
  // the paymentCollections rows below and maintained in the same transaction as
  // every collection write, so the collections queue can filter and sort in SQL
  // without aggregating a join on every request. paymentCollections stays the
  // source of truth; if these two ever disagree with it, trust the rows.
  paymentCollectionStatus PaymentCollectionStatus @default(NOT_REQUIRED)
  paymentCollectedAmount  Decimal                 @default(0) @db.Decimal(14, 4)
  paymentCollections      PaymentCollection[]

  // ── selected service / rate snapshot ──
  // mirrors Quote's snapshot philosophy: price/service locked at booking time.
  // markupPercentApplied records what was actually used for THIS shipment,
  // even though it's normally just copied from Org.markupPercent at booking time —
  // keeps the historical record correct if you ever change an Org's markup later.
  selectedVendorId       String?
  selectedVendorName     String?
  selectedProductName    String?
  markupPercentApplied   Decimal? @db.Decimal(6, 3)
  quotedTotal            Decimal? @db.Decimal(14, 4)
  currency               String   @default("INR")
  chargesSnapshot        Json? // full breakdown shown to customer at selection time
  serviceabilitySnapshot Json? // raw list of options shown, for audit/debugging

  // ── carrier / AWB tracking (air freight) ──
  // all optional — populated by ops once the vendor confirms booking
  mawbNumber        String? // Master Air Waybill — issued by the airline, covers the whole consolidated cargo
  hawbNumber        String? // House Air Waybill — issued to this specific shipper; usually what the client should track by
  carrierAirline    String? // e.g. "Emirates SkyCargo" — distinct from selectedVendorName (your logistics vendor/agent)
  vendorTrackingUrl String? // deep link to the carrier's public tracking page, if one exists
  awbAddedAt        DateTime? // when ops first recorded AWB info
  awbUpdatedAt      DateTime? // last time it was edited
  awbAddedById      String? // ops/staff user id who added it

  status ShipmentStatus @default(DRAFT)

  walletTransactions WalletTransaction[]
  documents          ShipmentDocument[]
  statusHistory      ShipmentStatusEvent[]

  internalNotes String? // free-form ops notes, separate from customer-facing status

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookedAt  DateTime? // set when payment succeeds / status -> BOOKED

  @@index([orgId])
  @@index([orgId, status])
  @@index([clientId])
  @@index([createdAt])
  @@index([mawbNumber])
  @@index([hawbNumber])
  // Drives the arena collections queue: "which deferred bookings still owe us?"
  @@index([paymentDeferred, paymentCollectionStatus])
}

// ─────────────────────────────────────────────
// PackageItem — dimensions + contents per package
// (a shipment can have multiple packages/cartons)
// ─────────────────────────────────────────────

model PackageItem {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  // A PackageItem is a physical BOX. `quantity` = how many identical boxes
  // (same dimensions, weight and contents) — the UI tells the user to add a
  // separate box only when L/B/H, weight, OR contents differ.
  description String // short box-level summary, e.g. "Apparel carton" — derived from contents when present
  quantity    Int    @default(1)

  lengthCm Decimal @db.Decimal(8, 2)
  widthCm  Decimal @db.Decimal(8, 2)
  heightCm Decimal @db.Decimal(8, 2)
  weightKg Decimal @db.Decimal(8, 2)

  declaredValue    Decimal? @db.Decimal(14, 2) // sum of contents' value for one box (× quantity for total)
  declaredCurrency String?  @default("INR")

  hsCode String? // legacy box-level HS code; per-item HS now lives on contents

  // Items packed inside this box (Description / HSN / Qty / Price) — drives
  // the commercial invoice & customs packing list. A box can hold many items.
  contents PackageContentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shipmentId])
}

// ─────────────────────────────────────────────
// PackageContentItem — one line item inside a box.
// (Description / HSN / Qty / unit value) — a box can
// contain many. Powers the invoice + customs packing list.
// ─────────────────────────────────────────────

model PackageContentItem {
  id            String      @id @default(cuid())
  packageItemId String
  packageItem   PackageItem @relation(fields: [packageItemId], references: [id], onDelete: Cascade)

  description String
  hsCode     String? // HSN code for this specific item
  quantity   Int     @default(1)
  unitValue  Decimal @db.Decimal(14, 2) // price/value per unit, in `currency`
  currency   String  @default("INR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([packageItemId])
}

// ─────────────────────────────────────────────
// ShipmentDocument — invoice (mandatory, per-shipment)
// + ops-added docs (AWB etc.) over the shipment lifecycle
// ─────────────────────────────────────────────

model ShipmentDocument {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  docType ShipmentDocType
  label   String

  fileUrl  String
  fileKey  String
  fileName String
  fileSize Int
  mimeType String

  visibleToClient Boolean @default(true) // ops can flag internal-only docs (e.g. vendor invoices, internal correspondence)

  uploadedByType String // "ORG" | "OPS" — keep simple, avoid a second enum unless you need more roles
  uploadedById   String? // orgId's user id, or staff/ops user id, depending on uploadedByType

  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shipmentId])
  @@index([shipmentId, docType])
}

// ─────────────────────────────────────────────
// ShipmentStatusEvent — audit trail / timeline.
// Every status change, who made it, optional note.
// Powers the dashboard timeline + any customer tracking view.
// ─────────────────────────────────────────────

model ShipmentStatusEvent {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  fromStatus ShipmentStatus?
  toStatus   ShipmentStatus

  note String?

  changedByType String // "ORG" | "OPS" | "SYSTEM"
  changedById   String?

  createdAt DateTime @default(now())

  @@index([shipmentId])
  @@index([shipmentId, createdAt])
}

// ─────────────────────────────────────────────
// BaApplication — tracks an Org's request to
// become a Business Associate (lower markup,
// gains access to the /clients route once approved).
// Kept even after approval, as a history record —
// don't delete on approve/reject, just update status.
// ─────────────────────────────────────────────

model BaApplication {
  id    String @id @default(cuid())
  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  status BaApplicationStatus @default(PENDING)

  // whatever you want to collect on the application form —
  // expected volume, business type, existing client base, etc.
  // kept as JSON so the form can evolve without a migration.
  formData Json?

  reviewedBy  String? // ops/admin user id who approved/rejected
  reviewedAt  DateTime?
  reviewNotes String?

  // snapshot of the markup granted on approval — copy into
  // Org.markupPercent when you flip isBusinessAssociate, but
  // keep it here too so you know what was offered vs. later changed
  approvedMarkupPercent Decimal? @db.Decimal(6, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([status])
}

// ─────────────────────────────────────────────
// BookingDraft — a half-finished booking, saved
// per "Save & Next" step so the user can leave and
// resume. Holds the whole wizard state as JSON plus
// the step they're on. The real Shipment + Address
// rows are only materialised at final submit, so the
// Shipment table stays 100% real bookings (no DRAFT
// clutter, no nullable address FKs).
// ─────────────────────────────────────────────

model BookingDraft {
  id    String @id @default(cuid())
  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  userId String // Clerk user id who owns this draft

  currentStep Int  @default(0)
  data        Json // serialized BookingFormData

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One in-progress draft per user per org is the intent; enforced in the
  // action layer (find-then-update/create) rather than a DB unique, so the
  // additive push stays non-destructive.
  @@index([orgId])
  @@index([orgId, userId])
}

// ─────────────────────────────────────────────
// SystemNotice — the info banner Arena ops show
// across the tenant dashboard. Freight moves on
// events outside the app (carrier strikes, port
// congestion, rate revisions, holiday closures),
// so ops needs a way to say so without a deploy.
//
// Not org-owned: a notice is authored by Arena
// staff and targeted at an audience segment, so
// there is no orgId FK here.
// ─────────────────────────────────────────────

enum NoticeSeverity {
  INFO // neutral update — new feature, general information
  SUCCESS // resolved / good news — backlog cleared, service restored
  WARNING // heads-up that needs planning — rate revision, cut-off change
  CRITICAL // acting now matters — carrier hold, payments down
}

enum NoticeAudience {
  ALL
  BUSINESS_ASSOCIATES // orgs with isBusinessAssociate = true
  STANDARD // orgs shipping for themselves
}

enum NoticeDisplayMode {
  ALWAYS // visible from the moment it is switched on until switched off
  SCHEDULED // visible only inside the startsAt/endsAt window
}

model SystemNotice {
  id String @id @default(cuid())

  title   String? // optional short headline, e.g. "Air freight delay"
  message String // the notice body — plain text, no markup

  severity    NoticeSeverity    @default(INFO)
  audience    NoticeAudience    @default(ALL)
  displayMode NoticeDisplayMode @default(ALWAYS)

  // Kill switch, independent of the schedule. A SCHEDULED notice can be drafted
  // with isActive = false and armed later without touching its window.
  isActive Boolean @default(false)

  // false pins the notice open — used for CRITICAL notices a tenant must not be
  // able to hide (customs hold, wallet debits paused).
  dismissible Boolean @default(true)

  // Tiebreak when several notices are live at once. Higher wins.
  priority Int @default(0)

  startsAt DateTime? // SCHEDULED only; null means "from now"
  endsAt   DateTime? // SCHEDULED only; null means "until switched off"

  linkLabel String? // CTA text, e.g. "View revised rates"
  linkHref  String? // internal path ("/domestic-rates") or absolute URL

  // Bumped whenever the visible content changes. Tenant-side dismissals are
  // keyed by id + revision, so editing a live notice re-surfaces it to people
  // who already dismissed the previous wording.
  revision Int @default(1)

  createdBy String? // Clerk userId of the Arena staffer who authored it
  updatedBy String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt, isActive])
  @@index([deletedAt, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// DEFERRED PAYMENT COLLECTION
//
// Orgs with Org.skipPayment book without paying up front; the money is taken
// later, typically in cash or by UPI when the parcel reaches the hub. Before
// this, Shipment.paymentDeferred recorded that it happened but nothing recorded
// whether we were ever paid.
//
// One row per time money changes hands, rather than a single boolean, so part
// payments work and there is a permanent record of who took what. A mistaken
// entry is reversed (admin only), never deleted, so the mistake stays visible.
// ═══════════════════════════════════════════════════════════════════════════

enum PaymentCollectionStatus {
  NOT_REQUIRED // paid from the wallet at booking time, nothing is owed
  PENDING // booked without paying, nothing collected yet
  PART_PAID // some money in, a balance still owed
  COLLECTED // fully settled
  WRITTEN_OFF // ops accepted this will never be collected
}

enum PaymentCollectionMethod {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  CARD
  OTHER
}

model PaymentCollection {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  amount   Decimal                 @db.Decimal(14, 4) // always positive
  currency String                  @default("INR")
  method   PaymentCollectionMethod

  /// UPI reference, cheque number, bank UTR — whatever proves this payment.
  reference String?
  note      String?

  /// When the money actually changed hands, which is not always when it was
  /// recorded. Ops may enter Friday's cash on Monday, and the reports should
  /// count it on Friday.
  collectedAt DateTime

  recordedByUserId String?
  recordedByName   String?

  /// Reversal is a state, not a delete. Any arena member can record a
  /// collection; only an admin can reverse one. A reversed row is excluded from
  /// every total but stays in the history with its reason attached.
  reversedAt     DateTime?
  reversedByUserId String?
  reversedByName String?
  reversalReason String?

  createdAt DateTime @default(now())

  @@index([shipmentId])
  @@index([reversedAt, collectedAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// CLIENT-FACING EMAIL PREFERENCE
//
// See Org.clientEmailsEnabled for the full reasoning. INHERIT is the default so
// the org-wide toggle stays meaningful: only clients a BA has explicitly pinned
// stop following it.
// ═══════════════════════════════════════════════════════════════════════════

enum ClientEmailPreference {
  INHERIT // follow the org setting, whatever it is now or later
  ALWAYS // email this client even when the org setting is off
  NEVER // never email this client even when the org setting is on
}

// ═══════════════════════════════════════════════════════════════════════════
// NOTIFICATION INBOX
//
// A durable record of things that happened, alongside (not instead of) email.
// Email reaches people who are not logged in; the inbox is the scrollable
// history that survives a deleted mail.
//
// Addressed to a SCOPE rather than to individual users. An ARENA notification is
// for whoever is on shift, and an ORG one is for whoever from that org logs in.
// Two consequences that were the point of the design:
//
//   - Somebody added to the org next month still sees everything that came
//     before, because nothing was ever fanned out to a fixed list of users.
//   - Read state is per user (NotificationReceipt), so one person opening the
//     bell does not clear the badge for their colleagues.
// ═══════════════════════════════════════════════════════════════════════════

enum NotificationScope {
  ARENA // internal ops and admin
  ORG // one tenant organisation
}

enum NotificationKind {
  // ── Arena side ──
  BOOKING_PLACED // a tenant just booked
  PAYMENT_FAILED // a top-up the bank rejected; money kind, so admin only
  COLLECTION_OVERDUE // a deferred payment nobody has collected
  SHIPMENT_STUCK // sat in the same status past the tolerance
  QUOTE_EXPIRING // a sent quote about to lapse

  // ── Tenant side ──
  SHIPMENT_STATUS // their shipment moved
  ARENA_MESSAGE // ops wrote to them directly
}

model Notification {
  id String @id @default(cuid())

  scope NotificationScope
  /// Required for ORG scope, always null for ARENA. Enforced in lib/notifications/emit.ts.
  orgId String?
  org   Org?   @relation(fields: [orgId], references: [id], onDelete: Cascade)

  kind NotificationKind
  /// Reuses the notice palette so a warning looks the same everywhere in the app.
  severity NoticeSeverity @default(INFO)

  title String
  body  String?

  /// Where the row takes you. In-app path only, validated before it is written.
  linkHref String?

  // ARENA scope only. Money figures are hidden from non-admin arena members
  // everywhere else, so a notification carrying an amount must not turn up in an
  // ops member's inbox and reintroduce the leak by the back door.
  adminOnly Boolean @default(false)

  // Natural key for anything a scheduled job re-evaluates on every run. The job
  // computes the same key for the same real-world fact, so the unique constraint
  // turns a repeat run into a no-op instead of a duplicate row. Null for events
  // that fire exactly once by nature, like a booking being placed.
  dedupeKey String? @unique

  /// Set when the notification is about one shipment, for the link and for cleanup.
  shipmentId String?
  /// Clerk userId when a human authored this, null when the system did.
  createdBy String?

  createdAt DateTime @default(now())

  receipts NotificationReceipt[]

  // Covers the two inbox reads: the arena feed and one org's feed. createdAt is
  // in the index because every read is "newest first".
  @@index([scope, createdAt(sort: Desc)])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([kind, createdAt])
}

model NotificationReceipt {
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  /// Clerk userId. Not a relation: users live in Clerk, not here.
  userId String

  // A row existing IS the read mark. Written when someone opens the bell or hits
  // "mark all as read", never in advance, so the table only grows with actual
  // reads rather than with (notifications x members).
  readAt DateTime @default(now())

  // The pair is the identity, so the upsert needs no surrogate key and the
  // "have I read this" lookup is served by the primary key index alone.
  @@id([notificationId, userId])
  @@index([userId])
}
